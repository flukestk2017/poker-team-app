generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String         @id @default(cuid())
  username          String         @unique
  displayName       String
  pin               String
  role              String         @default("member")
  discordWebhook    String?
  notifyHoursBefore Int            @default(1)
  createdAt         DateTime       @default(now())

  // Email auth fields
  email             String?        @unique
  password          String?
  emailVerified     DateTime?
  verifyToken       String?        @unique
  verifyTokenExpiry DateTime?
  isActive          Boolean        @default(true)

  tasks             DailyTask[]
  userTasks         UserTask[]
  journals          JournalEntry[]
  handTags          HandTag[]
  feedPosts         FeedPost[]
  feedComments      FeedComment[]
  screenshots       Screenshot[]
}

model DailyTask {
  id                String    @id @default(cuid())
  userId            String
  date              String
  taskKey           String
  completed         Boolean   @default(false)
  deadline          DateTime?
  notifyHoursBefore Int?
  user              User      @relation(fields: [userId], references: [id])

  @@unique([userId, date, taskKey])
}

model UserTask {
  id        String   @id @default(cuid())
  userId    String
  taskKey   String
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, taskKey])
}

model JournalEntry {
  id           String   @id @default(cuid())
  userId       String
  date         String
  sessionNote  String   @default("")
  quickJournal String   @default("")
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model HandTag {
  id        String   @id @default(cuid())
  userId    String
  date      String
  tagText   String
  imageUrl  String?
  linkUrl   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model FeedPost {
  id        String        @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  comments  FeedComment[]
}

model FeedComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      FeedPost @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Screenshot {
  id          String   @id @default(cuid())
  url         String
  storagePath String
  takenBy     String?
  note        String?
  createdAt   DateTime @default(now())

  userId      String?
  user        User?    @relation(fields: [userId], references: [id])

  @@map("screenshots")
}
